// ══════════════════════════════════════════════════════════════════════════════
// Footmap Volume Map v1.0
// A footprint-style volume heatmap indicator for TradingView
// PineScript v6
// ══════════════════════════════════════════════════════════════════════════════
//@version=6
indicator("Footmap Volume Map", shorttitle="FootMap", overlay=true,
     max_boxes_count=500, max_labels_count=500, max_bars_back=5000)

// ─── Inputs ─────────────────────────────────────────────────────────────────

// Structure
i_rows       = input.int(10, "Price Levels (Rows)", minval=2, maxval=40,
                 group="Structure",
                 tooltip="Number of price level rows per bar")
i_lookback   = input.int(5, "Display Bars", minval=1, maxval=20,
                 group="Structure",
                 tooltip="Number of recent bars to render the footmap on")
i_ltf        = input.timeframe("1", "Lower Timeframe",
                 group="Structure",
                 tooltip="Granularity for volume distribution. Use a timeframe lower than the chart.")

// Display Options
i_showDelta  = input.bool(true, "Show Delta per Level",
                 group="Display",
                 tooltip="Display buy−sell delta at each price level")
i_showPOC    = input.bool(true, "Highlight POC (Point of Control)",
                 group="Display",
                 tooltip="Highlight the price level with the highest volume")
i_showTotal  = input.bool(true, "Show Bar Totals",
                 group="Display",
                 tooltip="Show total volume and delta above each bar")
i_showVol    = input.bool(true, "Show Volume Numbers",
                 group="Display",
                 tooltip="Show volume numbers at each price level")
i_mode       = input.string("Heatmap", "Color Mode",
                 options=["Heatmap", "Delta"],
                 group="Display",
                 tooltip="Heatmap: intensity by total volume. Delta: color by buy/sell dominance.")

// Colors
i_buyColor   = input.color(#26a69a, "Buy Volume Color",   group="Colors")
i_sellColor  = input.color(#ef5350, "Sell Volume Color",   group="Colors")
i_pocColor   = input.color(#ffeb3b, "POC Border Color",    group="Colors")
i_textColor  = input.color(#e0e0e0, "Text Color",          group="Colors")
i_bgNeutral  = input.color(color.new(#2a2e39, 70), "Neutral Background", group="Colors")
i_deltaPos   = input.color(#00e676, "Positive Delta Label", group="Colors")
i_deltaNeg   = input.color(#ff1744, "Negative Delta Label", group="Colors")

// ─── Lower Timeframe Data ───────────────────────────────────────────────────

[ltfOpen, ltfClose, ltfHigh, ltfLow, ltfVolume] = request.security_lower_tf(
     syminfo.tickerid, i_ltf, [open, close, high, low, volume])

// ─── Helper Functions ───────────────────────────────────────────────────────

// Estimate buy volume from a single bar using the close-location-value method.
// CLV = (close − low) / (high − low) → proportion attributed to buying.
estimateBuyVolume(float o, float c, float h, float l, float v) =>
    float rng = h - l
    float bv  = rng > 0 ? v * (c - l) / rng : v * 0.5
    bv

// Map a price to a row index (0-based).
priceToRow(float price, float base, float step, int rows) =>
    int idx = int(math.floor((price - base) / step))
    math.max(0, math.min(idx, rows - 1))

// Format large numbers for display (e.g., 1500 → "1.5K").
formatVol(float v) =>
    string result = ""
    if v >= 1000000
        result := str.tostring(math.round(v / 1000000, 1)) + "M"
    else if v >= 1000
        result := str.tostring(math.round(v / 1000, 1)) + "K"
    else
        result := str.tostring(math.round(v))
    result

// ─── Per-Bar Volume Distribution ────────────────────────────────────────────

// We build volume profiles on every bar so they're available for the drawing
// pass on the last bar.

// Persistent storage: a flat float array of size (maxBars × rows × 2).
// Layout per bar-slot: [buyVol_row0, sellVol_row0, buyVol_row1, sellVol_row1, …]
int   maxSlots   = i_lookback
int   slotSize   = i_rows * 2
int   totalCells = maxSlots * slotSize

var float[] volStore = array.new_float(totalCells, 0.0)

// On each new bar, shift data left (drop oldest slot, make room for newest).
if barstate.isconfirmed or barstate.islast
    // Shift: move slot[1..N-1] → slot[0..N-2]
    if maxSlots > 1
        for s = 0 to maxSlots - 2
            int dstBase = s * slotSize
            int srcBase = (s + 1) * slotSize
            for c = 0 to slotSize - 1
                array.set(volStore, dstBase + c, array.get(volStore, srcBase + c))

    // Clear the newest slot (last slot).
    int newBase = (maxSlots - 1) * slotSize
    for c = 0 to slotSize - 1
        array.set(volStore, newBase + c, 0.0)

    // Fill newest slot with the current bar's data.
    float barRng   = high - low
    float rh       = barRng > 0 ? barRng / i_rows : 0.0

    if barRng > 0 and array.size(ltfVolume) > 0
        // Distribute lower-timeframe volumes into rows.
        for i = 0 to array.size(ltfVolume) - 1
            float tO = array.get(ltfOpen, i)
            float tC = array.get(ltfClose, i)
            float tH = array.get(ltfHigh, i)
            float tL = array.get(ltfLow, i)
            float tV = array.get(ltfVolume, i)

            float bv   = estimateBuyVolume(tO, tC, tH, tL, tV)
            float sv   = tV - bv
            int   rLow = priceToRow(tL, low, rh, i_rows)
            int   rHi  = priceToRow(tH, low, rh, i_rows)
            int   span = rHi - rLow + 1
            float bvPr = bv / span
            float svPr = sv / span

            for r = rLow to rHi
                int off = newBase + r * 2
                array.set(volStore, off,     array.get(volStore, off)     + bvPr)
                array.set(volStore, off + 1, array.get(volStore, off + 1) + svPr)

    else if barRng > 0
        // Fallback when no LTF data: uniform distribution from aggregate bar.
        float bv = estimateBuyVolume(open, close, high, low, volume)
        float sv = volume - bv
        for r = 0 to i_rows - 1
            int off = newBase + r * 2
            array.set(volStore, off,     bv / i_rows)
            array.set(volStore, off + 1, sv / i_rows)

// ─── Store per-bar OHLC for historical lookback drawing ─────────────────────

var float[] hOpen  = array.new_float(maxSlots, 0.0)
var float[] hClose = array.new_float(maxSlots, 0.0)
var float[] hHigh  = array.new_float(maxSlots, 0.0)
var float[] hLow   = array.new_float(maxSlots, 0.0)
var float[] hVol   = array.new_float(maxSlots, 0.0)

if barstate.isconfirmed or barstate.islast
    if maxSlots > 1
        for s = 0 to maxSlots - 2
            array.set(hOpen,  s, array.get(hOpen,  s + 1))
            array.set(hClose, s, array.get(hClose, s + 1))
            array.set(hHigh,  s, array.get(hHigh,  s + 1))
            array.set(hLow,   s, array.get(hLow,   s + 1))
            array.set(hVol,   s, array.get(hVol,   s + 1))
    int last = maxSlots - 1
    array.set(hOpen,  last, open)
    array.set(hClose, last, close)
    array.set(hHigh,  last, high)
    array.set(hLow,   last, low)
    array.set(hVol,   last, volume)

// ─── Drawing (executed on the last bar only) ────────────────────────────────

if barstate.islast
    // Clean up old drawings.
    int existingBoxes  = box.all.size()
    if existingBoxes > 0
        for i = 0 to existingBoxes - 1
            box.delete(box.all.first())

    int existingLabels = label.all.size()
    if existingLabels > 0
        for i = 0 to existingLabels - 1
            label.delete(label.all.first())

    // Draw each bar in the lookback window.
    for b = 0 to maxSlots - 1
        int   barIdx  = bar_index - (maxSlots - 1 - b)
        float bHigh   = array.get(hHigh, b)
        float bLow    = array.get(hLow, b)
        float bRange  = bHigh - bLow
        float rh      = bRange > 0 ? bRange / i_rows : 0.0

        if bRange <= 0
            continue

        int   slotBase = b * slotSize

        // ── First pass: find max volume in this bar (for heatmap scaling) & POC
        float maxVol   = 0.0
        int   pocRow   = 0
        float barDelta = 0.0

        for r = 0 to i_rows - 1
            int   off = slotBase + r * 2
            float bv  = array.get(volStore, off)
            float sv  = array.get(volStore, off + 1)
            float tv  = bv + sv
            barDelta += bv - sv
            if tv > maxVol
                maxVol := tv
                pocRow := r

        // ── Second pass: draw boxes and labels
        for r = 0 to i_rows - 1
            float levelLow  = bLow + r * rh
            float levelHigh = levelLow + rh
            int   off       = slotBase + r * 2
            float bv        = array.get(volStore, off)
            float sv        = array.get(volStore, off + 1)
            float tv        = bv + sv
            float delta     = bv - sv

            // ── Color calculation
            float intensity = maxVol > 0 ? tv / maxVol : 0.0
            color bgCol     = i_bgNeutral

            if i_mode == "Heatmap"
                bgCol := color.from_gradient(intensity, 0.0, 1.0,
                             i_bgNeutral,
                             delta >= 0 ? i_buyColor : i_sellColor)
            else // Delta mode
                if delta > 0
                    bgCol := color.from_gradient(intensity, 0.0, 1.0,
                                 i_bgNeutral, i_buyColor)
                else
                    bgCol := color.from_gradient(intensity, 0.0, 1.0,
                                 i_bgNeutral, i_sellColor)

            // ── POC border
            bool  isPOC     = r == pocRow and i_showPOC
            color borderCol = isPOC ? i_pocColor : color.new(#757575, 60)
            int   borderW   = isPOC ? 2 : 1

            // ── Draw the box for this price level
            box.new(barIdx, levelHigh, barIdx, levelLow,
                 border_color=borderCol, border_width=borderW,
                 bgcolor=bgCol, border_style=line.style_solid)

            // ── Volume / delta label
            if i_showVol and tv > 0
                string txt = formatVol(tv)
                if i_showDelta
                    string sign = delta >= 0 ? "+" : ""
                    txt += " " + sign + formatVol(delta)
                label.new(barIdx, (levelHigh + levelLow) / 2.0, txt,
                     style=label.style_none, textcolor=i_textColor,
                     size=size.tiny)

        // ── Bar total label above the bar
        if i_showTotal
            float totalVol = array.get(hVol, b)
            string totTxt  = "Vol " + formatVol(totalVol)
            if i_showDelta
                string dSign = barDelta >= 0 ? "+" : ""
                totTxt += "  Δ" + dSign + formatVol(barDelta)
            color totCol = barDelta >= 0 ? i_deltaPos : i_deltaNeg
            label.new(barIdx, bHigh + bRange * 0.05, totTxt,
                 style=label.style_label_down, textcolor=i_textColor,
                 color=totCol, size=size.small)

// ─── Plot: invisible series so the Data Window shows useful values ──────────
float _totalVol = volume
float _buyVol   = estimateBuyVolume(open, close, high, low, volume)
float _sellVol  = _totalVol - _buyVol
float _delta    = _buyVol - _sellVol

plot(_totalVol, "Total Volume", display=display.data_window)
plot(_buyVol,   "Est. Buy Vol", display=display.data_window)
plot(_sellVol,  "Est. Sell Vol", display=display.data_window)
plot(_delta,    "Delta",         display=display.data_window)

// ══════════════════════════════════════════════════════════════════════════════
// END
// ══════════════════════════════════════════════════════════════════════════════
